# URL du backend API (NestJS)
# En développement local : http://localhost:3000/api/v1
# En production : https://votre-backend.railway.app/api/v1 (ou autre hébergeur)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# URL publique du frontend (utilisée par le service worker / manifest)
NEXT_PUBLIC_APP_URL=http://localhost:3002
