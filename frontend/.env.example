# URL du backend API (NestJS)
# En développement local : http://localhost:3000/api/v1
# En production : https://votre-backend.railway.app/api/v1 (ou autre hébergeur)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# URL publique du frontend (utilisée par le sitemap, robots.txt, partages)
# En développement : http://localhost:3002
# En production : https://wenddtransport.com
NEXT_PUBLIC_APP_URL=http://localhost:3002

# PostgreSQL (Render) — utilisé par les routes API Next.js (/app/api/*)
# Format : postgresql://user:password@hostname:5432/database
# ⚠️  Ne jamais préfixer par NEXT_PUBLIC_ (secret serveur uniquement)
DATABASE_URL=postgresql://user:password@hostname.render.com:5432/database
