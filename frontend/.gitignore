# ─────────────────────────────────────────────────────────────
#  VTC Dakar — Frontend (Next.js) .gitignore
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────
/.next/
/out/
/build

# ── Tests & Coverage ──────────────────────────────────────────
/coverage
.nyc_output/

# ── Environment (secrets) ─────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
!.env.example

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Debug & Logs ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS ────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────
*.pem
.cache/
