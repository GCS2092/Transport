# ─────────────────────────────────────────────────────────────
#  VTC Dakar — Root .gitignore
# ─────────────────────────────────────────────────────────────

# ── Documentation & Design ────────────────────────────────────
documentation/
DESING
TEMPLATES1.png
TEMPLATES2.png
test.html
*.docx
*.pdf
*.zip
*.png
*.jpg
*.jpeg
!**/public/images/*.jpeg
!**/public/images/*.jpg
!**/public/images/*.png
!**/public/images/*.svg
*.svg
*.ico

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & Editors ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ── Environment files (secrets) ───────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Keep examples
!.env.example

# ── Frontend (Next.js) ────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── Backend (NestJS) ──────────────────────────────────────────
backend/dist/
backend/coverage/
backend/*.tsbuildinfo
backend/.nyc_output/

# ── Misc ──────────────────────────────────────────────────────
*.pem
.cache/
tmp/
temp/
