# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# CORS : Origines autorisées (séparées par des virgules)
# Exemples : Vercel, domaine custom, etc.
ALLOWED_ORIGINS=https://transport-six-xi.vercel.app,https://vtcdakar.com

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=Transport

# JWT
JWT_ACCESS_SECRET=your_very_long_access_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_very_long_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d

# Email (Gmail SMTP — mot de passe d'application Google)
# Générer sur : https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre.adresse@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=votre.adresse@gmail.com
MAIL_FROM_NAME=VTC Dakar

# WhatsApp Click-to-Chat (numéro support)
WHATSAPP_SUPPORT_NUMBER=221XXXXXXXXX

# Sentry
SENTRY_DSN=https://your_sentry_dsn_here

# Admin initial (créé au démarrage si inexistant)
ADMIN_EMAIL=admin@vtcdakar.com
ADMIN_PASSWORD=ChangeMe_Strong_Password_123!
